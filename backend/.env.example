# Server
PORT=8080
# Comma-separated allowed origins for CORS (use * to allow all)
CORS_ORIGIN=http://localhost:3000

# AI provider: anthropic | openai | gemini
AI_PROVIDER=gemini

# Provide the key for the provider you chose
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional model overrides
ANTHROPIC_MODEL=claude-sonnet-4-5
OPENAI_MODEL=gpt-4o-mini
# gemini-2.5-flash-lite has the most generous free tier (higher RPM and RPD
# than gemini-2.5-flash) and is plenty for structured field mapping.
GEMINI_MODEL=gemini-2.5-flash-lite

# Extraction tuning
# Free-tier Gemini keys allow ~10-15 requests/minute; keep BATCH_SIZE high and
# concurrency low so an import uses as few requests as possible.
BATCH_SIZE=40
MAX_CONCURRENT_BATCHES=2
MAX_RETRIES=3
MAX_FILE_SIZE_MB=5
